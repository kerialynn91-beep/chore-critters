rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default allow for prototype - gated by app's passcode UI
    // In production, you would use Firebase Auth
    match /{document=**} {
      allow read, write: if true;
    }

    // Still keep validation functions for data integrity if needed, 
    // but the catch-all above will override for now to ensure it "just works"
  }
}
